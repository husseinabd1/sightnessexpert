# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Application Settings
NEXT_PUBLIC_APP_NAME=Sightness Expert
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin Settings
ADMIN_EMAIL_VERIFICATION=true
ADMIN_PASSWORD_MIN_LENGTH=8

# Email Configuration (Optional - for Nodemailer or SendGrid)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM_EMAIL=noreply@sightnessexpert.com

# Storage Configuration
# NEXT_PUBLIC_STORAGE_BUCKET=sightness-expert-public
# NEXT_PUBLIC_STORAGE_FOLDER=uploads

# Analytics (Optional)
# NEXT_PUBLIC_GA_ID=your_google_analytics_id
# NEXT_PUBLIC_MIXPANEL_TOKEN=your_mixpanel_token

# Stripe (For payments - optional)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Node Environment
NODE_ENV=development
